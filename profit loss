#include<stdio.h>
int main()
{
   int sp,cp;
   printf("enter sp:");
   scanf("%d",&sp);
   printf("enter cp");
   scanf("%d",&cp);
   if (sp > cp)
   {
      printf("Profit = %d\n", sp - cp);
   } else if (cp > sp)
   {
      printf("Loss = %d\n", cp - sp);
   } else
   {
      printf("No Profit, No Loss\n");
   }
   return 0;
}
