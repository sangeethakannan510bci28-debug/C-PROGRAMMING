#include<stdio.h>
#include<math.h>
int main()
{
    float P, R, T, SI, CI;
    printf("Enter Principal Amount (P): ");
    scanf("%f", &P);
    printf("Enter Rate of Interest in percentage (R): ");
    scanf("%f", &R);
    printf("Enter Time in years (T): ");
    scanf("%f", &T);
    SI = (P * T * R) / 100;
    CI = P * (pow((1 + R / 100), T) - 1);
    printf("\nSimple Interest: %.2f", SI);
    printf("\nCompound Interest: %.2f\n", CI);
    return 0;
}
